    { "ipa": "β", "respelling": "b", "notes": "voiced bilabial approximant (intervocalic b/v); rendered as b for English readability (lobo → LOH-boh)" },
    { "ipa": "d", "respelling": "d", "notes": "voiced dental stop word-initial or after nasal/lateral" },
    { "ipa": "ð", "respelling": "th", "notes": "voiced dental approximant (intervocalic d); like English 'th' in 'this' (nada → NAH-thah). Casual: render as 'd' if learner finds 'th' confusing." },
    { "ipa": "g", "respelling": "g", "notes": "voiced velar stop before a/o/u or after nasal; always hard, never the soft English 'g' in 'gem'" },
    { "ipa": "ɣ", "respelling": "g", "notes": "voiced velar approximant (intervocalic g); rendered as g for readability (lago → LAH-goh)" },
